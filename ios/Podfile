# Force Firebase to use static frameworks
$RNFirebaseAsStaticFramework = true

# Ensure correct Node binary
ENV['NODE_BINARY'] = '/usr/local/bin/node'
ENV['RCT_NEW_ARCH_ENABLED'] = '0'


# Resolve react_native_pods.rb with node to allow for hoisting
require Pod::Executable.execute_command('node', ['-p',
  'require.resolve(
    "react-native/scripts/react_native_pods.rb",
    {paths: [process.argv[1]]},
  )', __dir__]).strip

# iOS minimum deployment target
platform :ios, '15.1'

use_frameworks! :linkage => :static
prepare_react_native_project!

target 'CleanersChoice' do
  config = use_native_modules!

  # React Native core setup
  use_react_native!(
    :path => config[:reactNativePath],
    :app_path => "#{Pod::Config.instance.installation_root}/..",
    :hermes_enabled => false,
    :fabric_enabled => false ,
    :new_arch_enabled => false
  )

  $RNGetRandomValues_USE_TURBOMODULES = false

  # 🔔 Notifee (Local Notifications)
  pod 'RNNotifee', :path => '../node_modules/@notifee/react-native'

  # 💳 Stripe SDK
  pod 'Stripe', '~> 24.20.0'
  pod 'StripePayments', '~> 24.20.0'
  pod 'StripePaymentsUI', '~> 24.20.0'
  pod 'StripeApplePay', '~> 24.20.0'

# 🗺️ React Native Maps (Google)
rn_maps_path = '../node_modules/react-native-maps'
pod 'react-native-maps', :path => rn_maps_path

pod 'GoogleMaps', '~> 8.4'
pod 'Google-Maps-iOS-Utils', '~> 5.0'


  # 🧩 gRPC dependencies (for Firebase Firestore)
  pod 'glog', :podspec => '../node_modules/react-native/third-party-podspecs/glog.podspec'
  pod 'gRPC-C++'  # Let Firebase resolve the correct version
  pod 'gRPC-Core' # Let Firebase resolve the correct version

  post_install do |installer|
    # React Native's default post install
    react_native_post_install(
      installer,
      config[:reactNativePath],
      mac_catalyst_enabled: false
    )

    installer.pods_project.targets.each do |target|
      target.build_configurations.each do |config|
        # ✅ Ensure consistent deployment target
        config.build_settings['IPHONEOS_DEPLOYMENT_TARGET'] = '15.1'

        # ✅ Fix non-modular include error
        config.build_settings['CLANG_ALLOW_NON_MODULAR_INCLUDES_IN_FRAMEWORK_MODULES'] = 'YES'

        # ✅ Fix gRPC missing UPB headers
        if target.name == 'gRPC-C++'
          config.build_settings['HEADER_SEARCH_PATHS'] ||= ['$(inherited)']
          config.build_settings['HEADER_SEARCH_PATHS'] << '$(PODS_ROOT)/gRPC-C++/third_party/upb'
        end

        # ✅ Avoid simulator arch issues
        config.build_settings['EXCLUDED_ARCHS[sdk=iphonesimulator*]'] = 'arm64'
        config.build_settings['ONLY_ACTIVE_ARCH'] = 'YES'
      end

      # ✅ Clean up unused privacy bundles
      next unless target.respond_to?(:resources_build_phase)
      ['leveldb-library', 'boost'].each do |lib|
        next unless target.name == lib
        target.resources_build_phase.files.each do |file|
          if file.display_name.downcase.include?('privacy.bundle')
            target.resources_build_phase.remove_file_reference(file.file_ref)
          end
        end
      end
    end
  end
end
