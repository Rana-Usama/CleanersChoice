# Force Firebase to use static frameworks
$RNFirebaseAsStaticFramework = true
# Point NODE_BINARY to the correct Node location
ENV['NODE_BINARY'] = '/usr/local/bin/node' 

# Resolve react_native_pods.rb with node to allow for hoisting
require Pod::Executable.execute_command('node', ['-p',
  'require.resolve(
    "react-native/scripts/react_native_pods.rb",
    {paths: [process.argv[1]]},
  )', __dir__]).strip

platform :ios, '15.1'

use_frameworks! :linkage => :static
prepare_react_native_project!

target 'CleanersChoice' do
  config = use_native_modules!

  use_react_native!(
    :path => config[:reactNativePath],
    :app_path => "#{Pod::Config.instance.installation_root}/..",
    :hermes_enabled => false
  )

  # Notifee (local notifications)
  pod 'RNNotifee', :path => '../node_modules/@notifee/react-native'

  # gRPC dependencies
 pod 'glog', :podspec => '../node_modules/react-native/third-party-podspecs/glog.podspec'
pod 'gRPC-Core'
pod 'gRPC-C++'

  # Stripe SDK
  pod 'Stripe', '~> 24.20.0'
  pod 'StripePayments', '~> 24.20.0'
  pod 'StripePaymentsUI', '~> 24.20.0'
  pod 'StripeApplePay', '~> 24.20.0'

  post_install do |installer|
    # 👇 React Native’s default post-install
    react_native_post_install(
      installer,
      mac_catalyst_enabled: false
    )

    installer.pods_project.targets.each do |target|
      target.build_configurations.each do |config|
        # Ensure consistent deployment target
        config.build_settings['IPHONEOS_DEPLOYMENT_TARGET'] = '15.0'

        # ✅ Fix non-modular include error
        config.build_settings['CLANG_ALLOW_NON_MODULAR_INCLUDES_IN_FRAMEWORK_MODULES'] = 'YES'

        # ✅ Fix gRPC missing UPB headers
        if target.name == 'gRPC-C++'
          config.build_settings['HEADER_SEARCH_PATHS'] ||= ['$(inherited)']
          config.build_settings['HEADER_SEARCH_PATHS'] << '$(PODS_ROOT)/gRPC-C++/third_party/upb'
        end
      end

      # ✅ Skip aggregate targets that don’t have resources
      next unless target.respond_to?(:resources_build_phase)

      # ⚡ Remove bogus privacy bundles
      if target.name == 'leveldb-library'
        target.resources_build_phase.files.each do |file|
          if file.display_name == "leveldb_Privacy.bundle"
            target.resources_build_phase.remove_file_reference(file.file_ref)
          end
        end
      end

      if target.name == 'boost'
        target.resources_build_phase.files.each do |file|
          if file.display_name == "boost_privacy.bundle"
            target.resources_build_phase.remove_file_reference(file.file_ref)
          end
        end
      end
    end
  end
end
